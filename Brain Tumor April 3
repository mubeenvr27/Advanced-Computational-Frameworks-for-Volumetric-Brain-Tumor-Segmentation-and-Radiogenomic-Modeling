er.setLevel(logging.INFO)\n\nfor epoch in range(start_epoch, CFG.max_epochs + 1):\n    t0 = time.time()\n    tr_loss = train_epoch(model, train_loader, epoch)\n    if epoch % CFG.val_interval == 0 or epoch == 1:\n        vl, md_val, rd = validate(val_loader, epoch)\n        val_str = f\"{vl:<8.4f} | {md_val:<8.4f} | {rd['TC']:<8.4f} | {rd['WT']:<8.4f} | {rd['ET']:<8.4f}\"\n        if md_val > best_dice:\n            best_dice = md_val\n            raw_m = model.module if hasattr(model, \"module\") else model\n            torch.save({\"epoch\": epoch, \"model_state_dict\": raw_m.state_dict(), \"best_mean_dice\": best_dice}, checkpoint_path)\n    else:\n        val_str = f\"{'N/A':<8} | {'N/A':<8} | {'N/A':<8} | {'N/A':<8} | {'N/A':<8}\"\n    scheduler.step()\n    elapsed = time.time() - t0\n    print(f\"{epoch:03d}/{CFG.max_epochs:03d} | {tr_loss:<8.4f} | {val_str} | {elapsed:>4.0f}s\")\n\nprint(\"Phase 3 complete.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-04T08:43:38.603411Z","iopub.execute_input":"2026-04-04T08:43:38.603705Z"}},"outputs":[{"name":"stdout","text":"--- Found Checkpoint! Loading weights from /kaggle/working/best_model_try1.pth ---\nResuming from Epoch 21 | Current Best Dice: 0.8831\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Epoch 21 [Train]:   0%|          | 0/469 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":""}},"metadata":{}},{"name":"stdout","text":"021/050 | 0.2840   | N/A      | N/A      | N/A      | N/A      | N/A      | 1005s\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"Epoch 22 [Train]:   0%|          | 0/469 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":""}},"metadata":{}},{"name":"stdout","text":"022/050 | 0.2709   | N/A      | N/A      | N/A      | N/A      | N/A      |  966s\n","output_type":"stream"},{"output_type"